#!/usr/bin/env bash
set -e

which http > /dev/null

SCRIPT_DIR="$(dirname "$0")"
PLAYER=""

if [[ "$1" =~ https?://[^/]*mangalib ]]; then
    PLAYER="$SCRIPT_DIR/mangalib.sh"
elif [[ "$1" =~ https?://[^/]*remanga ]]; then
    PLAYER="$SCRIPT_DIR/mangalib.sh"
elif [[ "$1" =~ https?://[^/]*kodik ]]; then
    PLAYER="$SCRIPT_DIR/kodik.sh"
elif http GET "$1" | grep -q "RalodePlayer\.init"; then
    PLAYER="$SCRIPT_DIR/ralode.sh"
fi

exec "$PLAYER" "$1"
